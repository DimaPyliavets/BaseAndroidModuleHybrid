<?xml version="1.0" encoding="utf-8"?>
<!--
    res/layout/hybrid_widget_layout.xml
    Базовий layout для превью віджета (не для Glance рендерингу).
    ⚠️ ЗМІНИТИ: відповідно до твого дизайну
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/white">

    <!-- ⚠️ ЗМІНИТИ: текст та стиль -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hybrid Widget"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Дані оновлюються..."
        android:textSize="12sp" />

</LinearLayout>
