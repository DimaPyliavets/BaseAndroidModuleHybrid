<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    ⚠️ ЗМІНИТИ:
      - package: твій реальний applicationId
      - android:label: назва додатка що відображається користувачу
      - android:icon / android:roundIcon: заміни на свої ресурси
      - authorities у FileProvider: має збігатися з applicationId
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ─── Дозволи ─────────────────────────────────────────────────── -->
    <!-- Потрібен для завантаження оновлень з GitHub -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Потрібен для WorkManager offline-scheduling -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Для показу сповіщень (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Для Glance Widget -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Для планування фонових задач -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".HybridApp"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BaseAndroidModuleHybrid"
        android:usesCleartextTraffic="true">

        <!-- ─── Головна Activity ──────────────────────────────────────── -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ─── WorkManager: UpdateWorker ────────────────────────────── -->
        <!--
            ⚠️ ВАЖЛИВО: WorkManager реєструється автоматично через ContentProvider.
            Якщо використовуєш кастомну ініціалізацію — додай:
            tools:node="remove" для дефолтного WorkManagerInitializer
        -->

        <!-- ─── FileProvider для sharing файлів (якщо потрібно) ──────── -->
        <!--
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.baseandroidmodulehybrid.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        -->

        <!-- ─── Glance Widget Receiver ───────────────────────────────── -->
        <receiver
            android:name=".widget.HybridWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/hybrid_widget_info" />
        </receiver>

    </application>
</manifest>
